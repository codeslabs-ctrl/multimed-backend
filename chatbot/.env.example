# Puerto del microservicio (por defecto 3999)
PORT=3999

# URL del backend Node (DemoMed API) - puerto 3001
BACKEND_URL=http://localhost:3001/api/v1

# Proveedor de IA: openai | claude | gemini (default: openai)
AI_PROVIDER=openai

# --- OpenAI (chat + Whisper para transcripción de voz) ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini ---
GEMINI_API_KEY=AIzaSyD0ENtdI9xQ2VBNBWACunPLsJUdJJMqbyU
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Nota voz: Con gemini la transcripción de voz usa Gemini (no hace falta OPENAI_API_KEY).
# Con claude la transcripción sigue usando Whisper; define OPENAI_API_KEY para voz.

# true = Tool Use (CHAT_TOOLS); false = flujo legacy __ACTION__ (SYSTEM_PROMPT). Default: true
USE_TOOL_CALLING=true
